  "angular-cli": {},
  "packageManager": "yarn@1.22.21",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "yarn": "node node_modules/yarn/bin/yarn.js",
    "build": "ng build",
    "test": "ng test",
    "extract_local": "ng extract-i18n --output-path src/assets/locale --format=json",
    "prod_old": "ng build --aot --configuration production",
    "prod": "ng build --localize --configuration production --optimization true --aot true && yarn run addversion",
    "dev": "ng build --localize && yarn run addversion",
    "serve": "ng serve --proxy-config proxy.conf.js --verbose",
    "addversion": "node add_version_to_scripts.js",
    "extract-translations_new": "ng extract-i18n --output-path src/assets/locale_pro --format=json",
    "extract-translation": "npx locl extract -s=./target/webapp/**/*.js -f=json -o=./src/assets/locale/en2.json",
    "serve:ssr:dcm4chee-arc-ui2": "node target/webapp/server/server.mjs"
  },
  "private": true,
